{
  "kind": "collectionType",
  "collectionName": "work_times",
  "info": {
    "singularName": "work-time",
    "pluralName": "work-times",
    "displayName": "Рабочие часы",
    "description": ""
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "date": {
      "type": "date",
      "required": true
    },
    "startTime": {
      "type": "customField",
      "customField": "global::time-slot",
      "default": "10:00",
      "required": true
    },
    "endTime": {
      "type": "customField",
      "customField": "global::time-slot",
      "default": "19:00",
      "required": true
    },
    "sum": {
      "type": "decimal",
      "required": true
    },
    "comment": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      },
      "required": true
    },
    "personal": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::personal.personal",
      "inversedBy": "work_time"
    }
  }
}
